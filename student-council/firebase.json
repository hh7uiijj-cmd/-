{
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": ["firebase.json","**/.*","**/node_modules/**","storage.rules"],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [{"key": "Cache-Control","value": "no-cache, no-store, must-revalidate"}]
      },
      {
        "source": "**/*.js",
        "headers": [{"key": "Cache-Control","value": "no-cache, no-store, must-revalidate"}]
      }
    ]
  }
}
